# ================================================================
# KibaAlo v2.0 — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# ================================================================

# ── SUPABASE ──────────────────────────────────────────────────────
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_ANON_KEY=votre_anon_key
SUPABASE_SERVICE_KEY=votre_service_role_key

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=changez_moi_en_production_kibaalo_2025_secret_very_long
JWT_EXPIRES_IN=7d

# ── SERVEUR ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=https://kibaalo-frontend.vercel.app
API_URL=https://kibaalo-backend.onrender.com

# ── EMAIL SMTP ────────────────────────────────────────────────────
# Option 1: Gmail (gratuit, 500 emails/jour)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_app_password_gmail
# Option 2: SendGrid (gratuit 100 emails/jour)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=votre_sendgrid_api_key

# ── CLOUDINARY (upload images/fichiers — gratuit 25GB) ────────────
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ── PAIEMENTS AFRIQUE DE L'OUEST ─────────────────────────────────

# Orange Money (BF, NE, ML, SN, CI, GN, CM, MR)
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/bf/v1
ORANGE_MONEY_CLIENT_ID=votre_client_id
ORANGE_MONEY_CLIENT_SECRET=votre_client_secret
ORANGE_MONEY_MERCHANT_KEY=votre_merchant_key
ORANGE_MONEY_WEBHOOK_SECRET=votre_webhook_secret

# Moov Money / Flooz (BF, NE, TG, BJ, CI, GN)
MOOV_MONEY_API_URL=https://api.moov-africa.bf/v1
MOOV_MONEY_TOKEN=votre_token
MOOV_MONEY_WEBHOOK_SECRET=votre_webhook_secret

# Wave (SN, CI, ML, BF)
WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=votre_api_key
WAVE_WEBHOOK_SECRET=votre_webhook_secret

# MTN Mobile Money (GH, NG, CI, CM, BJ, GN)
MTN_MONEY_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=votre_subscription_key
MTN_API_USER=votre_api_user
MTN_API_KEY=votre_api_key
MTN_ACCESS_TOKEN=votre_access_token
MTN_MONEY_WEBHOOK_SECRET=votre_webhook_secret

# Airtel Money (BF, NE, TD, MG, ZM)
AIRTEL_API_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=votre_client_id
AIRTEL_CLIENT_SECRET=votre_client_secret
AIRTEL_MONEY_WEBHOOK_SECRET=votre_webhook_secret

# Free Money (SN)
FREE_MONEY_API_URL=https://api.free.sn/money
FREE_MONEY_API_KEY=votre_api_key

# ── LIVRAISON ─────────────────────────────────────────────────────
MAX_DELIVERY_RADIUS_KM=15

# ── NOTIFICATIONS SMS (Africa's Talking) ─────────────────────────
AFRICAS_TALKING_API_KEY=votre_api_key
AFRICAS_TALKING_USERNAME=votre_username

# ── STOCKAGE FICHIERS DIGITAUX ────────────────────────────────────
# Les fichiers digitaux sont stockés sur Cloudinary
# Dossier: kibaalo/digital/
DIGITAL_PRODUCTS_FOLDER=kibaalo/digital
DIGITAL_MAX_DOWNLOADS=5
DIGITAL_EXPIRY_DAYS=30
