# ==============================================
# KibaAlo — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# ==============================================

# --- SUPABASE ---
# Obtenez ces valeurs sur https://supabase.com > Project Settings > API
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_ANON_KEY=votre_anon_key_ici
SUPABASE_SERVICE_KEY=votre_service_role_key_ici

# --- JWT ---
# Clé secrète pour signer les tokens (changez en production !)
JWT_SECRET=kibaalo_secret_jwt_changez_moi_en_production_2025
JWT_EXPIRES_IN=7d

# --- SERVEUR ---
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# --- PAIEMENT (à configurer selon votre opérateur) ---
# Orange Money API (Burkina Faso)
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/bf/v1
ORANGE_MONEY_CLIENT_ID=votre_client_id
ORANGE_MONEY_CLIENT_SECRET=votre_client_secret

# Moov Money API (Burkina Faso / Niger)
MOOV_MONEY_API_URL=https://api.moov-africa.bf/v1
MOOV_MONEY_TOKEN=votre_token

# --- NOTIFICATIONS SMS (Twilio ou Africa's Talking) ---
SMS_PROVIDER=africas_talking
AFRICAS_TALKING_API_KEY=votre_api_key
AFRICAS_TALKING_USERNAME=votre_username

# --- UPLOAD IMAGES (Cloudinary - gratuit 25GB) ---
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# --- RAYON LIVRAISON ---
MAX_DELIVERY_RADIUS_KM=15
